# =========================
# 👉 XDEBUG
# =========================
if [ "$COMMAND" == "xdebug" ]; then

  ACTION=$1

  # Devuelve líneas "label|bin|conf_dir|fpm_service" para cada PHP instalado
  discover_php_versions() {
    # PHP del sistema
    if command -v php &>/dev/null; then
      local ver
      ver=$(php -r 'echo PHP_MAJOR_VERSION.".".PHP_MINOR_VERSION;' 2>/dev/null || echo "?")
      echo "default (${ver})|php|/etc/php.d|php-fpm"
    fi

    # Versiones Remi: detectadas por sus directorios de configuración
    for confdir in /etc/opt/remi/php*/; do
      [ -d "${confdir}php.d" ] || continue
      local remi_name short ver bin_path
      remi_name=$(basename "$confdir")   # php82
      short=${remi_name#php}             # 82
      ver="${short:0:1}.${short:1}"      # 8.2

      # Buscar el binario de esta versión Remi
      bin_path=$(command -v "php${short}" 2>/dev/null \
               || echo "/opt/remi/${remi_name}/root/usr/bin/php")
      [ -x "$bin_path" ] || continue

      echo "remi-${ver}|${bin_path}|${confdir}php.d|${remi_name}-php-fpm"
    done
  }

  write_xdebug_ini() {
    local conf_dir=$1 mode=$2
    if [ "$mode" == "on" ]; then
      sudo tee "${conf_dir}/99-valet-xdebug.ini" > /dev/null <<'XEOF'
; Valet — Xdebug global config
xdebug.mode=debug,develop
xdebug.start_with_request=yes
xdebug.client_host=127.0.0.1
xdebug.client_port=9003
xdebug.discover_client_host=false
xdebug.idekey=VALET
XEOF
    else
      sudo tee "${conf_dir}/99-valet-xdebug.ini" > /dev/null <<'XEOF'
; Valet — Xdebug global config
xdebug.mode=off
XEOF
    fi
  }

  if [ "$ACTION" == "on" ] || [ "$ACTION" == "off" ]; then

    echo "🐛 Xdebug ${ACTION}..."
    echo ""
    found=0

    while IFS='|' read -r label bin_path conf_dir fpm_service; do
      if ! "$bin_path" --ri xdebug &>/dev/null; then
        printf "  ⚠️  %-24s Xdebug no instalado\n" "$label"
        if [[ "$label" == remi-* ]]; then
          ver=${label#remi-}; short=${ver/./}
          echo "       → sudo dnf install php${short}-php-pecl-xdebug3"
        else
          echo "       → sudo dnf install php-pecl-xdebug3"
        fi
        continue
      fi

      write_xdebug_ini "$conf_dir" "$ACTION"

      if systemctl is-active --quiet "$fpm_service"; then
        sudo systemctl restart "$fpm_service"
        printf "  ✅  %-24s reiniciado\n" "$label"
      else
        printf "  ✅  %-24s (inactivo, config escrita)\n" "$label"
      fi
      found=$((found + 1))
    done < <(discover_php_versions)

    echo ""
    if [ "$found" -eq 0 ]; then
      echo "❌ Ninguna versión de PHP tiene Xdebug instalado"
    else
      echo "✅ Xdebug ${ACTION} en ${found} versión(es) de PHP"
      [ "$ACTION" == "on" ] && echo "   Puerto: 9003 | IDE key: VALET"
    fi

  elif [ "$ACTION" == "status" ] || [ -z "$ACTION" ]; then

    echo ""
    echo "Estado de Xdebug por versión PHP:"
    echo ""

    while IFS='|' read -r label bin_path conf_dir fpm_service; do
      if ! "$bin_path" --ri xdebug &>/dev/null; then
        printf "  %-26s no instalado\n" "$label"
        continue
      fi
      mode=$("$bin_path" -r "echo ini_get('xdebug.mode');" 2>/dev/null || echo "off")
      if [[ "$mode" == *"debug"* ]]; then
        port=$("$bin_path" -r "echo ini_get('xdebug.client_port');" 2>/dev/null || echo "9003")
        printf "  %-26s ACTIVO   modo=%-18s puerto=%s\n" "$label" "$mode" "$port"
      else
        printf "  %-26s inactivo\n" "$label"
      fi
    done < <(discover_php_versions)

  else
    echo "❌ Uso: valet xdebug [on|off|status]"
    exit 1
  fi

  echo ""
fi

