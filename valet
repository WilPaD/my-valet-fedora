  echo ""

  echo "DNS:"
  resolv_target=$(readlink /etc/resolv.conf 2>/dev/null || echo "archivo regular")
  echo "  resolv.conf → $resolv_target"
  echo "  nameservers : $(grep '^nameserver' /etc/resolv.conf 2>/dev/null | awk '{print $2}' | tr '\n' ' ')"
  if nslookup google.com 127.0.0.1 &>/dev/null; then
    echo "  internet    : ✅ google.com resuelve via 127.0.0.1"
  else
    echo "  internet    : ❌ google.com NO resuelve via 127.0.0.1"
  fi
  if nslookup "valet-test.$TLD" 127.0.0.1 2>/dev/null | grep -q '127\.0\.0\.1'; then
    echo "  wildcard    : ✅ *.$TLD → 127.0.0.1"
  else
    echo "  wildcard    : ❌ *.$TLD no resuelve a 127.0.0.1"
  fi
  echo ""

  echo "Configuración:"
  echo "  TLD    : .$TLD"
  echo "  NM dns : $(grep '^dns=' /etc/NetworkManager/NetworkManager.conf 2>/dev/null || echo 'no configurado')"
  echo "  Home   : $VALET_HOME"
  echo "  Sites  : $(ls "$SITES_DIR" 2>/dev/null | wc -l) sitio(s) enlazados"
  echo ""

  echo "Nginx:"
  nginx_test=$(sudo nginx -t 2>&1) || true
  if echo "$nginx_test" | grep -q "successful"; then
    echo "  config : ✅ válida"
  else
    echo "  config : ❌ errores"
    echo "$nginx_test" | sed 's/^/  /'
  fi
  echo ""
fi

