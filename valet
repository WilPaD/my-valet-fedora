      global_ver=$(cat "$DEFAULT_PHP_FILE")
      global_socket=$(get_global_socket)
    else
      global_ver="sistema ($(php -r 'echo PHP_VERSION;' 2>/dev/null || echo '?'))"
      global_socket="/run/php-fpm/www.sock"
    fi
    echo "  Global : $global_ver  [$global_socket]"
    echo ""
    echo "  Por sitio:"

    found=0
    for link in "$SITES_DIR"/*/; do
      link="${link%/}"
      [ -e "$link" ] || [ -L "$link" ] || continue
      site_name=$(basename "$link")
      real_dir=$(readlink -f "$link" 2>/dev/null || true)
      if [ -f "$real_dir/.php-version" ]; then
        ver=$(cat "$real_dir/.php-version")
        printf "    %-30s %s\n" "$site_name.$TLD" "$ver"
        found=$((found + 1))
      fi
    done
    [ "$found" -eq 0 ] && echo "    (ninguno — todos usan la versión global)"
    echo ""
    exit 0
  fi

  # ── Validar formato ──────────────────────────────────────────────────────────
  if [ "$PHP_ARG" != "system" ]; then
    [[ "$PHP_ARG" =~ ^php@([0-9]+\.[0-9]+)$ ]] || {
      echo "❌ Uso: valet php [php@X.X|system] [--site=nombre]"
      exit 1
    }
    PHP_VERSION="${BASH_REMATCH[1]}"
    PHP_SHORT="${PHP_VERSION/./}"   # 8.2 → 82
    FPM_SERVICE="php${PHP_SHORT}-php-fpm"
  fi

  # ── Con --site: cambio per-site ──────────────────────────────────────────────
  if [[ "$SITE_ARG" =~ ^--site=(.+)$ ]]; then

    SITE_NAME="${BASH_REMATCH[1]}"
    SITE_CONF="$(nginx_site_conf "$SITE_NAME")"
    REAL_SITE_DIR=$(readlink -f "$SITES_DIR/$SITE_NAME" 2>/dev/null || true)

    [ -e "$SITES_DIR/$SITE_NAME" ] || { echo "❌ Sitio no encontrado: $SITE_NAME"; exit 1; }

    if [ "$PHP_ARG" == "system" ]; then
      sudo rm -f "$SITE_CONF" 2>/dev/null || true
      [ -n "$REAL_SITE_DIR" ] && rm -f "$REAL_SITE_DIR/.php-version" 2>/dev/null || true
      reload_nginx
      echo "✅ $SITE_NAME → versión global"
    else
      sudo systemctl enable --now "$FPM_SERVICE" \
        || { echo "❌ Servicio $FPM_SERVICE no encontrado. ¿Está instalado el paquete remi?"; exit 1; }
      sleep 1
      PHP_SOCKET=$(get_php_socket "$PHP_VERSION")
      [ -S "$PHP_SOCKET" ] || echo "⚠️  Socket aún no disponible: $PHP_SOCKET"

      echo "php@$PHP_VERSION" > "$REAL_SITE_DIR/.php-version"

      sudo tee "$SITE_CONF" > /dev/null <<EOF
server {
    listen 80;
    server_name $SITE_NAME.$TLD;

    root $SITES_DIR/$SITE_NAME/public;
    index index.php index.html;

    location / {
        try_files \$uri \$uri/ /index.php?\$query_string;
    }

    location ~ \\.php\$ {
        include fastcgi_params;
        fastcgi_pass unix:$PHP_SOCKET;
        fastcgi_param SCRIPT_FILENAME \$document_root\$fastcgi_script_name;
        fastcgi_param VALET_SITE_PATH $SITES_DIR/$SITE_NAME;
        fastcgi_param PHP_VALUE "auto_prepend_file=$VALET_HOME/server.php";
    }
}
EOF
      reload_nginx
      echo "✅ $SITE_NAME → PHP $PHP_VERSION  [$PHP_SOCKET]"
    fi

  # ── Sin --site: cambio global ────────────────────────────────────────────────
  else

    if [ "$PHP_ARG" == "system" ]; then
      echo "⚙️  Restaurando PHP del sistema como versión global..."
      rm -f "$DEFAULT_PHP_FILE"
      write_nginx_wildcard "$TLD" "/run/php-fpm/www.sock"
      sudo systemctl restart php-fpm
      reload_nginx
      echo "✅ PHP global → sistema ($(php -r 'echo PHP_VERSION;' 2>/dev/null || echo '?'))"
    else
