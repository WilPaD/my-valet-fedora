  SITE_DIR="$SITES_DIR/$SITE_NAME"

  # Quitar del trust del sistema
  sudo rm -f "/etc/pki/ca-trust/source/anchors/valet-$SITE_NAME.crt" 2>/dev/null || true
  sudo update-ca-trust 2>/dev/null || true

  rm -f "$CERT_KEY" "$CERT_CRT"

  # Si el sitio sigue aislado, regenerar su config HTTP sin HTTPS
  REAL_SITE_DIR=$(readlink -f "$SITE_DIR" 2>/dev/null || true)
  if [ -f "$REAL_SITE_DIR/.php-version" ]; then
    PHP_VER=$(cat "$REAL_SITE_DIR/.php-version" | sed 's/php@//')
    PHP_SOCKET=$(get_php_socket "$PHP_VER")
    sudo tee "$SITE_CONF" > /dev/null <<EOF
server {
    listen 80;
    server_name $SITE_NAME.$TLD;

    root $SITE_DIR/public;
    index index.php index.html;

    location / {
        try_files \$uri \$uri/ /index.php?\$query_string;
    }

    location ~ \\.php\$ {
