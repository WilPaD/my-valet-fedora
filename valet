  fi

  # Eliminar configs nginx
  echo "🌐 Eliminando configuración Nginx..."
  sudo rm -f "$NGINX_WILDCARD"
  sudo rm -f /etc/nginx/conf.d/valet-site-*.conf

  # Eliminar DNS
  if [ -f "/etc/NetworkManager/dnsmasq.d/valet.conf" ]; then
    echo "🌍 Eliminando DNS..."
    sudo rm -f /etc/NetworkManager/dnsmasq.d/valet.conf
    sudo sed -i '/^dns=dnsmasq/d' /etc/NetworkManager/NetworkManager.conf
    sudo systemctl restart NetworkManager

    # Restaurar dnsmasq standalone solo si estaba habilitado antes de valet install
    if [ -f "$VALET_HOME/.dnsmasq-was-enabled" ]; then
      sudo systemctl enable --now dnsmasq 2>/dev/null || true
      rm -f "$VALET_HOME/.dnsmasq-was-enabled"
    fi

    # Restaurar resolv.conf a systemd-resolved si el install lo cambió
    RESOLV_TARGET=$(readlink /etc/resolv.conf 2>/dev/null || true)
    if [[ "$RESOLV_TARGET" == *"NetworkManager/resolv.conf"* ]]; then
      echo "🔧 Restaurando resolv.conf a systemd-resolved..."
      sudo rm /etc/resolv.conf
      sudo ln -sf /run/systemd/resolve/stub-resolv.conf /etc/resolv.conf
      sudo systemctl restart systemd-resolved 2>/dev/null || true
    fi
  fi

  # Eliminar config Xdebug de Valet
  sudo rm -f /etc/php.d/99-valet-xdebug.ini 2>/dev/null || true
  for confdir in /etc/opt/remi/php*/php.d/; do
    sudo rm -f "${confdir}99-valet-xdebug.ini" 2>/dev/null || true
  done

  # Eliminar certs del trust del sistema
  sudo rm -f /etc/pki/ca-trust/source/anchors/valet-*.crt 2>/dev/null || true
  sudo update-ca-trust 2>/dev/null || true

  # Eliminar directorio de configuración (opcional)
  if [ -d "$VALET_HOME" ]; then
    read -p "¿Eliminar $VALET_HOME (sites, certs, config)? (y/N): " -n 1 -r; echo
    [[ $REPLY =~ ^[Yy]$ ]] && rm -rf "$VALET_HOME"
  fi

  # Eliminar shim de PHP
  rm -f "$HOME/.local/bin/php"

  sudo systemctl restart php-fpm 2>/dev/null || true
  sudo systemctl restart nginx  2>/dev/null || true

  echo ""
  echo "✅ Valet desinstalado completamente"
  echo ""
fi

